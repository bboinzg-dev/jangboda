DATABASE_URL="file:./dev.db"

# 실제 OCR 사용 시 채울 것 (없으면 mock OCR 사용)
CLOVA_OCR_URL=""
CLOVA_OCR_SECRET=""

# KAMIS 농수산물유통공사 공공 API (없으면 mock 시세 사용)
# 신청: https://www.kamis.or.kr/customer/reference/openapi_list.do
KAMIS_CERT_KEY=""
KAMIS_CERT_ID=""

# /api/sync/* 라우트 보호용 토큰 (수동 호출 시 X-Sync-Token 헤더로 전달)
# 미설정 시 인증 비활성화 (개발 모드)
SYNC_TOKEN=""

# Vercel Cron이 자동으로 보내는 인증 헤더 (Bearer 토큰)
# Vercel 대시보드 → Settings → Environment Variables → CRON_SECRET 자동 생성됨
CRON_SECRET=""

# Supabase Auth (Google OAuth 로그인용) + Storage (영수증 이미지 업로드용)
# Supabase 대시보드 → Settings → API 에서 복사
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# Storage 사용 시 추가 설정 필요:
#   1) Storage → New bucket → 이름 "receipts", Public 체크, file size limit 10MB
#   2) Policies → Public read + 인증 사용자 insert (README 참고)
# service_role key는 사용하지 않음 (anon key + RLS로 처리)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# 카카오맵 (선택, 마트 위치 표시용 — 현재는 OpenStreetMap 사용)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=""

# ─────────── 정부 혜택 추천 모듈 (/benefits) ───────────
# 신청: https://www.data.go.kr — 회원가입(개인 가능) → 데이터셋 활용신청(자동승인)
# 활용신청해야 하는 데이터: 15113968, 1421000/mssBizService_v2, 1421000/bizinfo, B554287/sclWlfrFcltInfoInqirService1, 사업자등록 진위확인
DATA_GO_KR_SERVICE_KEY=""

# 신청: https://www.bizinfo.go.kr/uss/rss/bizinfoApi.do (이메일로 키 통지)
BIZINFO_API_KEY=""

# 신청: https://data.seoul.go.kr → 인증키 신청 (즉시 발급)
SEOUL_DATA_KEY=""
