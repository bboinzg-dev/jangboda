{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/sync/kamis",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/sync/naver?limit=10&onlyMajor=true",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/alerts/check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/benefits-deadline",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/sync/recalls",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/sync/haccp",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/sync-benefits",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/sync/agritrace",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/sync/recipes",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/sync/health-functional",
      "schedule": "0 6 1 * *"
    }
  ],
  "functions": {
    "src/app/api/sync/naver/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/kamis/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/csv/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/recalls/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/haccp/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/agritrace/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/recipes/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/health-functional/route.ts": { "maxDuration": 60 },
    "src/app/api/alerts/check/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/benefits-deadline/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/sync-benefits/route.ts": { "maxDuration": 60 }
  }
}
