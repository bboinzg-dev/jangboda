{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/sync/kamis",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/sync/naver?limit=20&onlyMajor=true&chain=true",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/sync/naver?recent=2h&limit=20&onlyMajor=true",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/alerts/check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/benefits-deadline",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/sync/recalls",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/recall-check",
      "schedule": "10 */6 * * *"
    },
    {
      "path": "/api/sync/haccp",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/sync-benefits",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/normalize-benefits",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/stale-benefits",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/sync/agritrace",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/sync/recipes",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/sync/health-functional",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/sync/parsa",
      "schedule": "0 18 * * 6"
    },
    {
      "path": "/api/sync/parsa?type=standard",
      "schedule": "0 19 * * 6"
    },
    {
      "path": "/api/sync/parsa?type=prices",
      "schedule": "0 20 * * 6"
    },
    {
      "path": "/api/sync/parsa/mirror",
      "schedule": "0 21 * * 6"
    },
    {
      "path": "/api/sync/parsa/full-mirror?type=products",
      "schedule": "30 21 * * 6"
    },
    {
      "path": "/api/sync/parsa/full-mirror?type=prices&from=0&limit=10000&chain=true",
      "schedule": "0 22 * * 6"
    },
    {
      "path": "/api/sync/product-images?limit=30&chain=true",
      "schedule": "0 4 1 * *"
    },
    {
      "path": "/api/sync/parsa/enrich?chain=true",
      "schedule": "0 23 * * 6"
    }
  ],
  "functions": {
    "src/app/api/sync/naver/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/kamis/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/csv/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/recalls/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/haccp/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/agritrace/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/recipes/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/health-functional/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/parsa/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/parsa/mirror/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/parsa/full-mirror/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/parsa/enrich/route.ts": { "maxDuration": 60 },
    "src/app/api/alerts/check/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/benefits-deadline/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/sync-benefits/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/normalize-benefits/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/stale-benefits/route.ts": { "maxDuration": 60 },
    "src/app/api/sync/product-images/route.ts": { "maxDuration": 60 }
  }
}
